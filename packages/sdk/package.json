{
  "name": "sonar-sdk",
  "version": "0.2.0",
  "description": "Sonar SDK — error capture, deploy tracking, uptime monitoring, and web analytics.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "import": "./dist/index.browser.js",
        "types": "./dist/index.browser.d.ts"
      },
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/index.browser.js",
      "types": "./dist/index.browser.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.browser.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "sonar",
    "observability",
    "monitoring",
    "errors",
    "web-analytics",
    "sdk"
  ],
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonamadi/sonar.git",
    "directory": "packages/sdk"
  }
}
