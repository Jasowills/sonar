# ── Watchdog SDK configuration ──
# Get these values from your Watchdog workspace → settings → API keys.

# Your project slug (shown as the first part of URL when viewing your project)
WATCHDOG_PROJECT_KEY=my-awesome-api

# The environment key from your Watchdog environment (e.g. "prod", "staging")
WATCHDOG_ENVIRONMENT_KEY=env_production_key_here

# API key with ingest permissions — starts with "wdp_"
# Create one at: watchdog UI → Settings → API Keys
WATCHDOG_API_KEY=wdp_xxxxxxxx_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# The Watchdog server endpoint (leave as default for local dev)
WATCHDOG_ENDPOINT=http://localhost:8080

# Which port the testing-hub itself runs on
PORT=3001
